<div class="breadcrumbs">
  <a href="<%= root_path %>">Home</a>
  <span class="separator">/</span>
  <a href="<%= root_path %>weeks">All Weeks</a>
  <span class="separator">/</span>
  <%= @week_id %>
</div>

<div class="page-title">
  <h1>Week <%= @week_number %></h1>
  <p class="subtitle"><%= @date_range %></p>
</div>

<% if @events_by_category.empty? %>
  <p>No events found for this week.</p>
<% else %>
  <% @events_by_category.each do |category, events| %>
    <section class="category-section">
      <div class="category-header">
        <h2><%= category %></h2>
        <span class="category-count"><%= events.length %> event<%= events.length == 1 ? '' : 's' %></span>
      </div>
      <% events.each do |event| %>
        <div class="event-card fade-in">
          <div class="event-name">
            <% if event[:url] && !event[:url].empty? %>
              <a href="<%= event[:url] %>" target="_blank" rel="noopener"><%= event[:name] %></a>
            <% else %>
              <%= event[:name] %>
            <% end %>
          </div>
          <div class="event-meta">
            <% if event[:date_text] && !event[:date_text].empty? %>
              <span class="date"><%= event[:date_text] %></span>
            <% end %>
            <% if event[:venue] && !event[:venue].empty? %>
              <span class="venue"><%= event[:venue] %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>
<% end %>
