<div class="breadcrumbs">
  <a href="<%= root_path %>">Home</a>
  <span class="separator">/</span>
  <a href="<%= root_path %><%= @year %>"><%= @year %></a>
  <span class="separator">/</span>
  <%= @month_name %>
</div>

<div class="page-title">
  <h1><%= @month_name %> <%= @year %></h1>
  <p class="subtitle"><%= @total_events %> events</p>
</div>

<% if @days.any? %>
  <h3>Browse by day</h3>
  <ul class="archive-list" style="margin-bottom: 2rem;">
    <% @days.each do |day| %>
      <li>
        <a href="<%= root_path %><%= @year %>/<%= @month_path %>/<%= day[:path] %>">
          <span class="label"><%= day[:label] %></span>
          <span class="meta"><%= day[:event_count] %> events</span>
        </a>
      </li>
    <% end %>
  </ul>
<% end %>

<% @events_by_category.each do |category, events| %>
  <section class="category-section">
    <div class="category-header">
      <h2><%= category %></h2>
      <span class="category-count"><%= events.length %></span>
    </div>
    <% events.each do |event| %>
      <div class="event-card fade-in">
        <div class="event-name">
          <% if event[:url] && !event[:url].empty? %>
            <a href="<%= event[:url] %>"><%= event[:name] %></a>
          <% else %>
            <%= event[:name] %>
          <% end %>
          <% if event[:times_listed] && event[:times_listed] > 2 %>
            <span class="times-badge">seen <%= event[:times_listed] %>x</span>
          <% end %>
        </div>
        <div class="event-meta">
          <% if event[:date_text] && !event[:date_text].empty? %>
            <span class="date"><%= event[:date_text] %></span>
          <% end %>
          <% if event[:venue] && !event[:venue].empty? %>
            <span class="venue"><%= event[:venue] %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>
<% end %>
