<div class="page-title">
  <h1>This Week in Coventry</h1>
  <p class="subtitle"><%= @week_label %></p>
</div>

<%
  next_months = (1..6).map do |i|
    d = Date.today >> i
    { label: d.strftime("%B"), path: "#{root_path}#{d.year}/#{d.strftime('%m')}" }
  end
%>
<nav class="month-nav" aria-label="Browse by month">
  <% next_months.each do |m| %>
    <a href="<%= m[:path] %>" class="month-tab"><%= m[:label] %></a>
  <% end %>
</nav>

<% if @events_by_category.empty? %>
  <p class="no-events">No events listed for this week yet.</p>
<% else %>
  <%
    all_venues = @events_by_category.values.flatten
                   .map { |e| e[:venue].to_s.strip }
                   .reject { |v| v.empty? || v == "Unknown" }
                   .uniq.sort
  %>
  <% if all_venues.size > 1 %>
    <div class="venue-filter" id="venue-filter">
      <span class="venue-filter-label">Venue:</span>
      <button class="venue-chip active" data-venue="">All</button>
      <% all_venues.each do |venue| %>
        <button class="venue-chip" data-venue="<%= venue %>"><%= venue %></button>
      <% end %>
    </div>
  <% end %>

  <% @events_by_category.each do |category, events| %>
    <section class="category-section">
      <div class="category-header">
        <h2><%= category %></h2>
        <span class="category-count"><%= events.length %> event<%= events.length == 1 ? '' : 's' %></span>
      </div>
      <% events.each do |event| %>
        <div class="event-card fade-in" data-venue="<%= event[:venue] %>">
          <div class="event-name">
            <% if event[:url] && !event[:url].empty? %>
              <a href="<%= event[:url] %>"><%= event[:name] %></a>
            <% else %>
              <%= event[:name] %>
            <% end %>
            <% if event[:times_listed] && event[:times_listed] > 2 %>
              <span class="times-badge">seen <%= event[:times_listed] %>x</span>
            <% end %>
            <% if user_signed_in? && current_user.admin? %>
              <a href="<%= edit_admin_event_path(event[:id]) %>" class="admin-edit-link">edit</a>
            <% end %>
          </div>
          <div class="event-meta">
            <% if event[:date_text] && !event[:date_text].empty? %>
              <span class="date"><%= event[:date_text] %></span>
            <% end %>
            <% if event[:venue] && !event[:venue].empty? %>
              <span class="venue"><%= event[:venue] %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>
<% end %>

<% if user_signed_in? && current_user.admin? %>
  <div class="admin-publish-bar">
    <%= button_to "Publish Site", publish_admin_site_path, method: :post, class: "publish-btn" %>
  </div>
<% end %>
