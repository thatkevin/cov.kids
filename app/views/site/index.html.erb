<div class="page-title">
  <h1>This Week in Coventry</h1>
  <p class="subtitle"><%= @week_label || week_label %></p>
</div>

<%
  next_months = (1..6).map do |i|
    d = Date.today >> i
    { label: d.strftime("%B"), path: "#{root_path}#{d.year}/#{d.strftime('%m')}" }
  end
%>
<nav class="month-nav" aria-label="Browse by month">
  <% next_months.each do |m| %>
    <a href="<%= m[:path] %>" class="month-tab"><%= m[:label] %></a>
  <% end %>
</nav>

<% all_events_by_date = defined?(events_by_date) ? events_by_date : @events_by_date %>
<% all_undated        = defined?(undated_events)  ? undated_events  : @undated_events %>

<% if all_events_by_date.blank? && all_undated.blank? %>
  <p class="no-events">No events listed for this week yet.</p>
<% else %>

  <% all_events_by_date.each do |date, events| %>
    <% date_label = date.respond_to?(:strftime) ? date.strftime("%A %-d %B") : date.to_s %>
    <section class="category-section">
      <div class="category-header">
        <h2><%= date_label %></h2>
        <span class="category-count"><%= events.length %> event<%= events.length == 1 ? '' : 's' %></span>
      </div>
      <% events.each do |event| %>
        <div class="event-card fade-in">
          <div class="event-name">
            <% if event[:url] && !event[:url].empty? %>
              <a href="<%= event[:url] %>"><%= event[:name] %></a>
            <% else %>
              <%= event[:name] %>
            <% end %>
            <% if event[:times_listed] && event[:times_listed].to_i > 2 %>
              <span class="times-badge">seen <%= event[:times_listed] %>x</span>
            <% end %>
            <% if defined?(current_user) && respond_to?(:user_signed_in?) && user_signed_in? && current_user.admin? %>
              <a href="<%= edit_admin_event_path(event[:id]) %>" class="admin-edit-link">edit</a>
            <% end %>
          </div>
          <div class="event-meta">
            <% if event[:date_text] && !event[:date_text].empty? %>
              <span class="date"><%= event[:date_text] %></span>
            <% end %>
            <% if event[:venue] && !event[:venue].empty? %>
              <span class="venue"><%= event[:venue] %></span>
            <% end %>
            <% if event[:category] && !event[:category].empty? %>
              <span class="category-pill"><%= event[:category] %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>

  <% if all_undated && all_undated.any? %>
    <section class="category-section undated-section">
      <div class="category-header">
        <h2>Also this week</h2>
        <span class="category-count"><%= all_undated.length %> event<%= all_undated.length == 1 ? '' : 's' %></span>
      </div>
      <% all_undated.each do |event| %>
        <div class="event-card fade-in">
          <div class="event-name">
            <% if event[:url] && !event[:url].empty? %>
              <a href="<%= event[:url] %>"><%= event[:name] %></a>
            <% else %>
              <%= event[:name] %>
            <% end %>
            <% if event[:times_listed] && event[:times_listed].to_i > 2 %>
              <span class="times-badge">seen <%= event[:times_listed] %>x</span>
            <% end %>
            <% if defined?(current_user) && respond_to?(:user_signed_in?) && user_signed_in? && current_user.admin? %>
              <a href="<%= edit_admin_event_path(event[:id]) %>" class="admin-edit-link">edit</a>
            <% end %>
          </div>
          <div class="event-meta">
            <% if event[:date_text] && !event[:date_text].empty? %>
              <span class="date"><%= event[:date_text] %></span>
            <% end %>
            <% if event[:venue] && !event[:venue].empty? %>
              <span class="venue"><%= event[:venue] %></span>
            <% end %>
            <% if event[:category] && !event[:category].empty? %>
              <span class="category-pill"><%= event[:category] %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>

<% end %>

<% if defined?(current_user) && respond_to?(:user_signed_in?) && user_signed_in? && current_user.admin? %>
  <div class="admin-publish-bar">
    <%= button_to "Publish Site", publish_admin_site_path, method: :post, class: "publish-btn" %>
  </div>
<% end %>
