<%= turbo_stream_from "admin_feeds" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-semibold text-gray-900">Feeds</h1>
  <%= link_to "Add feed", new_admin_feed_path, class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-md" %>
</div>

<% if @feeds.empty? %>
  <p class="text-gray-500 text-sm">No feeds configured yet.</p>
<% else %>
  <div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-100">
    <% @feeds.each do |feed| %>
      <%= render "feed_row", feed: feed %>
    <% end %>
  </div>
<% end %>
