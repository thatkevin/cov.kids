<%= form_with model: [:admin, feed], class: "space-y-4 max-w-lg" do |f| %>
  <% if feed.errors.any? %>
    <div class="rounded-md bg-red-50 border border-red-200 p-3">
      <ul class="list-disc list-inside text-sm text-red-700 space-y-0.5">
        <% feed.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500",
        placeholder: "e.g. Earlsdon Library" %>
  </div>

  <div>
    <%= f.label :url, "URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.url_field :url, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500",
        placeholder: "https://example.com/events" %>
  </div>

  <div>
    <%= f.label :feed_type, "Type", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :feed_type, Feed::FEED_TYPES.map { |t| [t.capitalize, t] },
        {}, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
  </div>

  <div>
    <%= f.label :fetch_interval_hours, "Fetch every (hours)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.number_field :fetch_interval_hours, min: 1, max: 168,
        class: "w-32 rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
  </div>

  <div>
    <%= f.label :default_category, "Default category", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <p class="text-xs text-gray-400 mb-1">If set, all events from this feed will be assigned this category regardless of what is extracted.</p>
    <%= f.select :default_category,
        [["— let Claude decide", ""]] + Event::CATEGORIES.map { |c| [c.capitalize, c] },
        { selected: feed.default_category.presence || "" },
        class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :active, class: "rounded border-gray-300" %>
    <%= f.label :active, "Active", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit feed.new_record? ? "Add feed" : "Save changes",
        class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-md cursor-pointer" %>
    <%= link_to "Cancel", admin_feeds_path, class: "text-sm text-gray-600 hover:underline self-center" %>
  </div>
<% end %>
