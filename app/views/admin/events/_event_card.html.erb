<div id="event-<%= event.id %>" class="bg-white border border-gray-200 rounded-lg p-4 mb-3 transition-all" data-moderation-target="card" data-url="<%= event.effective_event_url %>" data-event-id="<%= event.id %>">
  <div class="flex items-start gap-4">
    <% if event.image_url.present? %>
      <div class="shrink-0">
        <img src="<%= event.image_url %>" alt="" class="w-20 h-20 object-cover rounded" loading="lazy">
      </div>
    <% end %>
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2">
        <p class="font-medium text-gray-900 truncate"><%= event.effective_name %></p>
        <% if event.curated? %>
          <span class="shrink-0 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">edited</span>
        <% end %>
        <% if event.featured? %>
          <span class="shrink-0 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-700">★ featured</span>
        <% end %>
        <% if event.zone != "coventry" %>
          <span class="shrink-0 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium <%= event.zone == "birmingham" ? "bg-blue-100 text-blue-700" : "bg-orange-100 text-orange-700" %>">
            <%= event.zone == "birmingham" ? "brum" : "warks" %>
          </span>
        <% end %>
      </div>
      <div class="mt-1 flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500">
        <% if event.effective_venue.present? && event.effective_venue != "Unknown" %>
          <span><%= event.effective_venue %></span>
        <% end %>
        <% if event.effective_date_text.present? %>
          <span><%= event.effective_date_text %></span>
        <% end %>
        <% if event.effective_category.present? %>
          <span class="capitalize"><%= event.effective_category %></span>
        <% end %>
        <% if event.effective_event_url.present? %>
          <%= link_to "Link ↗", event.effective_event_url, target: "_blank", rel: "noopener", class: "text-blue-600 hover:underline" %>
          <code class="text-xs text-gray-400 bg-gray-100 px-1 py-0.5 rounded break-all"><%= event.effective_event_url %></code>
        <% end %>
      </div>
      <% if event.description.present? %>
        <p class="mt-1.5 text-sm text-gray-600 line-clamp-2"><%= event.description.truncate(200) %></p>
      <% end %>
      <% if event.source %>
        <p class="mt-1.5 text-xs text-gray-400">
          <span class="font-medium text-gray-500"><%= event.source.title %></span>
          · <%= event.source.source_type %>
          <% if event.source.published_at %>
            · <%= event.source.published_at.strftime("%-d %b %Y") %>
          <% end %>
        </p>
      <% end %>
    </div>
    <div class="flex flex-col gap-2 shrink-0">
      <div class="flex gap-2">
        <%= link_to "Edit", edit_admin_event_path(event), data: { turbo_stream: true }, class: "px-3 py-1.5 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 rounded" %>
        <%= button_to "Approve", approve_admin_event_path(event),
              method: :patch,
              class: "px-3 py-1.5 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded" %>
        <%= button_to "Reject", reject_admin_event_path(event),
              method: :patch,
              class: "px-3 py-1.5 text-sm font-medium text-white bg-red-500 hover:bg-red-600 rounded" %>
      </div>
      <% if event.image_url.present? %>
        <%= button_to event.featured? ? "★ Unfeature" : "☆ Feature",
              feature_admin_event_path(event),
              method: :patch,
              class: "px-3 py-1.5 text-sm font-medium #{event.featured? ? 'text-yellow-700 bg-yellow-100 hover:bg-yellow-200' : 'text-gray-600 bg-gray-100 hover:bg-gray-200'} rounded" %>
      <% end %>
    </div>
  </div>
</div>
