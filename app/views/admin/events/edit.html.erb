<div class="max-w-lg">
  <div class="mb-6">
    <%= link_to "← Back", :back, class: "text-sm text-blue-600 hover:underline" %>
  </div>

  <h1 class="text-xl font-semibold text-gray-900 mb-1">Edit event</h1>
  <p class="text-sm text-gray-400 mb-1">Overrides are shown to visitors; original imported values are preserved.</p>
  <% if @event.source %>
    <p class="text-xs text-gray-400 mb-6">
      <span class="font-medium text-gray-500"><%= @event.source.source_type %></span>
      · <%= link_to @event.source.title, @event.source.url, target: "_blank", rel: "noopener", class: "hover:underline" %>
      <% if @event.source.published_at %>· scraped <%= @event.source.published_at.strftime("%-d %b %Y") %><% end %>
    </p>
  <% end %>

  <%= form_with model: [:admin, @event], method: :patch, data: { turbo: false } do |f| %>
    <div class="space-y-4">

      <div>
        <label class="block text-xs font-medium text-gray-500 mb-0.5">Name</label>
        <p class="text-xs text-gray-400 mb-1 font-mono truncate">Original: <%= @event.name %></p>
        <%= f.text_field :curated_name,
            value: @event.effective_name,
            class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-500 mb-0.5">Venue</label>
        <p class="text-xs text-gray-400 mb-1 font-mono truncate">Original: <%= @event.venue.presence || "—" %></p>
        <%= f.text_field :curated_venue,
            value: @event.effective_venue,
            class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-500 mb-0.5">Date text <span class="font-normal text-gray-400">(shown to visitors)</span></label>
        <p class="text-xs text-gray-400 mb-1 font-mono">Original: <%= @event.date_text.presence || "—" %></p>
        <%= f.text_field :curated_date_text,
            value: @event.effective_date_text,
            class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-500 mb-0.5">Start date <span class="font-normal text-gray-400">(used for week filtering — YYYY-MM-DD)</span></label>
        <p class="text-xs text-gray-400 mb-1 font-mono">
          Parsed automatically: <%= @event.start_date&.strftime("%-d %b %Y") || "—" %>
          &nbsp;·&nbsp; First seen: <%= @event.first_seen.presence || "—" %>
          &nbsp;·&nbsp; Last seen: <%= @event.last_seen.presence || "—" %>
        </p>
        <%= f.date_field :start_date,
            value: @event.start_date,
            class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-500 mb-0.5">Ticket / event URL</label>
        <p class="text-xs text-gray-400 mb-1 font-mono truncate">Original: <%= @event.event_url.presence || "—" %></p>
        <%= f.url_field :curated_event_url,
            value: @event.effective_event_url,
            class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-500 mb-0.5">Category</label>
        <%= f.select :curated_category,
            [ ["— keep original (#{@event.category})", ""] ] + Event::CATEGORIES.map { |c| [c.capitalize, c] },
            { selected: @event.curated_category.presence || "" },
            class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
      </div>

    </div>

    <div class="mt-6 pt-4 border-t border-gray-100 flex items-center justify-between">
      <%= link_to "Cancel", :back, class: "text-sm text-gray-500 hover:text-gray-700" %>
      <%= f.submit "Save changes", class: "px-4 py-2 text-sm font-medium bg-blue-600 hover:bg-blue-700 text-white rounded-md cursor-pointer" %>
    </div>
  <% end %>

  <% if @similar_events&.any? %>
    <div class="mt-8 pt-6 border-t border-gray-200">
      <h2 class="text-sm font-semibold text-gray-700 mb-3">Similar events — merge duplicates</h2>
      <p class="text-xs text-gray-400 mb-3">This event will be kept; the selected duplicate will be absorbed and deleted.</p>
      <div class="space-y-2">
        <% @similar_events.each do |other| %>
          <div class="flex items-center gap-3 bg-gray-50 border border-gray-200 rounded px-3 py-2">
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-gray-800 truncate"><%= other.effective_name %></p>
              <p class="text-xs text-gray-400">
                <%= other.effective_date_text.presence || "no date" %>
                · <%= other.source&.source_type || "unknown" %>
                · <%= other.status %>
              </p>
            </div>
            <%= button_to "Merge in →",
                merge_admin_event_path(@event),
                params: { duplicate_event_ids: [other.id] },
                data: { turbo_confirm: "Absorb '#{other.effective_name}' into this event and delete it?" },
                class: "shrink-0 text-xs font-medium text-white bg-amber-600 hover:bg-amber-700 px-3 py-1.5 rounded" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
