<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-xl font-semibold text-gray-900">Venues</h1>
    <p class="text-sm text-gray-500 mt-1"><%= @venues.size %> venues · edit names/addresses, merge duplicates.</p>
  </div>
  <%= link_to "Add venue", new_admin_venue_path, class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-md" %>
</div>

<%# Possible duplicates panel %>
<% if @clusters.any? %>
  <div class="mb-8 bg-amber-50 border border-amber-200 rounded-lg p-4">
    <h2 class="text-sm font-semibold text-amber-800 mb-3">Possible duplicates (<%= @clusters.size %>)</h2>
    <div class="space-y-3">
      <% @clusters.each do |cluster| %>
        <div class="bg-white rounded border border-amber-100 divide-y divide-gray-100">
          <%# Canonical venue — the one that survives %>
          <div class="flex items-center gap-3 px-3 py-2">
            <span class="text-xs font-semibold text-green-700 bg-green-50 border border-green-200 rounded px-1.5 py-0.5 shrink-0">keep</span>
            <span class="text-sm font-medium text-gray-900"><%= cluster[:canonical].name %></span>
            <% if cluster[:canonical].address.present? %>
              <span class="text-xs text-gray-400 truncate"><%= cluster[:canonical].address %></span>
            <% end %>
            <span class="text-xs text-gray-400 shrink-0"><%= cluster[:canonical].events_count %> events</span>
            <%= link_to "Edit", edit_admin_venue_path(cluster[:canonical]), class: "text-xs text-blue-600 hover:underline shrink-0 ml-auto" %>
          </div>
          <%# Similar venues — each gets its own merge button %>
          <% cluster[:similar].each do |v| %>
            <div class="flex items-center gap-3 px-3 py-2">
              <span class="text-xs font-semibold text-red-600 bg-red-50 border border-red-200 rounded px-1.5 py-0.5 shrink-0">dup</span>
              <span class="text-sm text-gray-700"><%= v.name %></span>
              <% if v.address.present? %>
                <span class="text-xs text-gray-400 truncate"><%= v.address %></span>
              <% end %>
              <span class="text-xs text-gray-400 shrink-0"><%= v.events_count %> events</span>
              <div class="ml-auto flex items-center gap-2 shrink-0">
                <%= link_to "Edit", edit_admin_venue_path(v), class: "text-xs text-blue-600 hover:underline" %>
                <%= button_to "Merge into #{cluster[:canonical].name} →",
                    merge_admin_venue_path(cluster[:canonical]),
                    params: { source_venue_ids: [v.id] },
                    data: { turbo_confirm: "Move #{v.events_count} event(s) from '#{v.name}' to '#{cluster[:canonical].name}' and delete '#{v.name}'?" },
                    class: "text-xs bg-red-500 hover:bg-red-600 text-white px-3 py-1.5 rounded" %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Full venue list %>
<div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-100">
  <% zone_colors = { "coventry" => "bg-sky-100 text-sky-700", "warwickshire" => "bg-orange-100 text-orange-700", "birmingham" => "bg-blue-100 text-blue-700" } %>
  <% @venues.each do |venue| %>
    <div class="px-4 py-3 flex items-center gap-4">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <span class="font-medium text-gray-900 text-sm"><%= venue.name %></span>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= zone_colors[venue.zone] || 'bg-gray-100 text-gray-700' %>">
            <%= venue.zone %>
          </span>
          <% if venue.name == venue.address || venue.address.blank? %>
            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-700"
                  title="Name and address are the same — consider splitting them">needs cleanup</span>
          <% end %>
        </div>
        <% if venue.address.present? && venue.address != venue.name %>
          <p class="text-xs text-gray-400 mt-0.5"><%= venue.address %></p>
        <% end %>
        <p class="text-xs text-gray-400 mt-0.5"><%= venue.events_count %> event(s)</p>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        <%= link_to "Edit", edit_admin_venue_path(venue), class: "text-xs text-blue-600 hover:underline" %>
        <%= button_to "Remove", admin_venue_path(venue), method: :delete,
            data: { turbo_confirm: "Remove #{venue.name}? Events will be unlinked." },
            class: "text-xs text-red-500 hover:underline bg-transparent border-0 cursor-pointer p-0" %>
      </div>
    </div>
  <% end %>
</div>
