<%= form_with model: [:admin, venue], class: "space-y-4" do |f| %>
  <% if venue.errors.any? %>
    <div class="text-sm text-red-600 bg-red-50 border border-red-200 rounded p-3">
      <% venue.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1">Venue name <span class="text-red-500">*</span></label>
    <%= f.text_field :name, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500",
        placeholder: "e.g. Albany Theatre" %>
    <p class="mt-1 text-xs text-gray-400">Short display name only — no address here.</p>
  </div>

  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1">Address</label>
    <%= f.text_field :address, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500",
        placeholder: "e.g. Albany Rd, Coventry CV5 6JQ" %>
  </div>

  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1">Zone</label>
    <%= f.select :zone, Event::ZONES.map { |z| [z.capitalize, z] },
        {},
        class: "rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit venue.new_record? ? "Add venue" : "Save changes",
        class: "px-4 py-2 text-sm font-medium bg-blue-600 hover:bg-blue-700 text-white rounded-md cursor-pointer" %>
    <%= link_to "Cancel", admin_venues_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>
